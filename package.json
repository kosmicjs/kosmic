{
  "name": "spence-s-monorepo-template",
  "version": "0.0.0",
  "private": true,
  "description": "An opinionated typescript + ESM monorepo starter template for publishing npm packages.",
  "homepage": "https://github.com/spence-s/spence-s-monorepo-template",
  "bugs": {
    "url": "https://github.com/spence-s/spence-s-monorepo-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spence-s/spence-s-monorepo-template.git"
  },
  "license": "MIT",
  "author": {
    "name": "Spencer Snyder",
    "email": "sasnyde2@gmail.com",
    "url": "https://spencersnyder.io"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "changeset": "changeset",
    "check": "npm run check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rimraf dist",
    "dev": "npm run build -- --watch packages/* & npm run dev -w kosmic",
    "generate-package": "node scripts/generate/cli.ts",
    "lint": "xo",
    "prepare": "husky",
    "release": "npm run build && changeset publish",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "update": "ncu -i && npx --ws ncu -i",
    "version": "changeset version"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson"
    ]
  },
  "overrides": {
    "eslint": "9.38.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-check-updates": "^22.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.3",
    "swagger-ui-dist": "^5.32.6",
    "type-fest": "^5.7.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "xo": "^2.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
