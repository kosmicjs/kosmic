{
  "name": "@kosmic/config",
  "version": "0.0.2",
  "description": "Reusable configuration for Kosmic apps",
  "keywords": [
    "config",
    "configuration",
    "kosmic",
    "bootstrap"
  ],
  "license": "MIT",
  "author": {
    "name": "Spencer Snyder",
    "email": "sasnyde2@gmail.com",
    "url": "https://spencersnyder.io"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "check": "tsc --noEmit",
    "lint": "xo",
    "test": "node --test **/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.22.0",
    "type-fest": "^5.7.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  }
}
