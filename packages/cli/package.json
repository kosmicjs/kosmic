{
  "name": "@kosmic/cli",
  "version": "0.2.0",
  "license": "MIT",
  "author": {
    "name": "Spencer Snyder",
    "email": "sasnyde2@gmail.com",
    "url": "https://spencersnyder.io"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./migrate": {
      "import": {
        "types": "./dist/src/migrate/migrator.d.ts",
        "default": "./dist/src/migrate/migrator.js"
      }
    }
  },
  "bin": {
    "kosmic": "dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "check": "tsc --noEmit",
    "lint": "xo",
    "test": "node --test test/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "@kosmic/config": "^0.1.0",
    "execa": "^9.6.1",
    "kysely": "^0.29.3",
    "kysely-codegen": "^0.20.0",
    "p-wait-for": "^6.0.0",
    "path-exists": "^5.0.0",
    "pino": "^10.3.1",
    "pino-princess": "^1.6.3",
    "ts-to-zod": "^5.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3"
  },
  "engines": {
    "node": ">=22"
  }
}
