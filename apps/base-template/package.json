{
  "name": "base-template",
  "version": "0.0.0",
  "description": "A highly opinionated and strongly typed Koa web and api template.",
  "bugs": {
    "url": "https://github.com/spence-s/kosmic/issues"
  },
  "repository": {
    "url": "https://github/com/spence-s/kosmic"
  },
  "license": "MIT",
  "author": {
    "name": "Spencer Snyder",
    "email": "sasnyde2@gmail.com",
    "url": "https://spencersnyder.io"
  },
  "type": "module",
  "imports": {
    "#components/*": "./dist/src/components/*",
    "#models/*": "./dist/src/models/*",
    "#db/*": "./dist/src/db/*",
    "#emails/*": "./dist/src/emails/*",
    "#utils/*": "./dist/src/utils/*",
    "#islands/*": "./dist/src/client/islands/*",
    "#server": "./dist/src/server.js"
  },
  "main": "dist/src/index.js",
  "source": "./src/app/client/main.ts",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "kosmic build",
    "clean": "kosmic clean",
    "dev": "kosmic dev",
    "lint": "xo",
    "migrate": "kosmic migrate",
    "start": "kosmic start",
    "test": "kosmic test",
    "test:watch": "kosmic test:watch"
  },
  "dependencies": {
    "@kosmic/cli": "^0.0.4",
    "@kosmic/config": "^0.0.2",
    "@kosmic/core": "^0.0.4",
    "@kosmic/db": "^0.0.4",
    "@kosmic/logger": "^0.0.4",
    "@kosmic/router": "^0.0.2",
    "@kosmic/server": "^0.2.3",
    "@popperjs/core": "^2.11.8",
    "argon2": "^0.44.0",
    "camelcase": "^9.0.0",
    "clsx": "^2.1.1",
    "htmx.org": "^2.0.10",
    "humanize-string": "^3.1.0",
    "juice": "^11.1.1",
    "path-exists": "^5.0.0",
    "path-to-regexp": "^8.4.2",
    "preact": "^10.29.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "~25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-check-updates": "^22.2.1",
    "rimraf": "^6.1.3",
    "type-fest": "^5.7.0",
    "typed-htmx": "^0.3.1",
    "typescript": "~6.0.3"
  }
}
